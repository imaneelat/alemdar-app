generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model account_membership_profile {
  user_id            String   @id
  first_name         String?
  last_name          String?
  phone_country_code String   @default("+90")
  phone_local        String?
  country            String?
  city               String?
  address            String?
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
}

model account_security_preferences {
  user_id                  String    @id
  password_last_changed_at DateTime? @db.Timestamptz(6)
  created_at               DateTime  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime  @default(now()) @db.Timestamptz(6)
}

model account_subscription_preferences {
  user_id      String   @id
  email_opt_in Boolean  @default(true)
  sms_opt_in   Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
}

