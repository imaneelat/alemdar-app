/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model semantic_embeddings {
  id           BigInt                 @id @default(autoincrement())
  source_table String
  source_id    String
  name         String
  description  String?
  category     String?
  price        Decimal?               @db.Decimal
  image_url    String?
  search_text  String
  embedding    Unsupported("vector")?
  content_hash String
  created_at   DateTime               @default(now()) @db.Timestamptz(6)
  updated_at   DateTime               @default(now()) @db.Timestamptz(6)

  @@unique([source_table, source_id], map: "semantic_embeddings_source_unique")
  @@index([id, source_table, source_id, name, description, category, search_text, price, image_url], map: "idx_semantic_embeddings_bm25")
  @@index([category])
  @@index([embedding], map: "semantic_embeddings_embedding_hnsw_idx")
  @@index([name(ops: raw("gin_trgm_ops"))], map: "semantic_embeddings_name_trgm_idx", type: Gin)
  @@index([source_table, source_id], map: "semantic_embeddings_source_idx")
}

