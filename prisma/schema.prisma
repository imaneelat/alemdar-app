/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model arduino {
  id               Int      @id @default(autoincrement())
  english_names    String?  @db.VarChar(255)
  turkish_names    String?  @db.VarChar(255)
  category         String?  @db.VarChar(255)
  barcode          String?  @db.VarChar(255)
  quantity         Int?
  price            Decimal? @db.Decimal(10, 2)
  image_filename   String?
  description      String?
  category_layer_1 String?  @db.VarChar
  category_layer_2 String?  @db.VarChar

  @@index([category], map: "idx_arduino_category", where: raw("((category IS NOT NULL) AND ((category)::text <> ''::text))"))
  @@index([id, english_names, image_filename, category, quantity, price, description], map: "idx_arduino_id_covering")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model arduino_category_options {
