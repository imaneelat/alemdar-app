/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model main {
  id                  Int       @id
  english_name        String?   @db.VarChar
  turkish_name        String?   @db.VarChar
  barcode             String?   @db.VarChar
  kodu                String?
  price               Decimal?  @db.Decimal(10, 2)
  whole_price         Decimal?  @db.Decimal
  bought_price        Decimal?  @db.Decimal
  doller_bought_price Decimal?  @db.Decimal
  bought_time         DateTime? @db.Date
  kalan_miktar        Decimal?  @db.Decimal
  image_filename      String?
  category            String?
  sub_category        String?
  subsub_category     String?
  quantity            Decimal?  @db.Decimal
  description         String?

  @@index([category], map: "idx_main_category", where: raw("(category IS NOT NULL)"))
  @@index([category], map: "idx_main_category_sound", where: raw("(category = 'Sound'::text)"))
  @@index([id, english_name, image_filename, category, sub_category, quantity, price, description], map: "idx_main_id_covering", where: raw("(category = 'Sound'::text)"))
  @@index([sub_category], map: "idx_main_sub_category", where: raw("(sub_category IS NOT NULL)"))
}

